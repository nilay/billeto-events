<% events.each do |event| %>
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 shadow-sm">
      <% if event.image_url %>
        <img src="<%= event.image_url %>" class="card-img-top" alt="<%= event.name %>" style="height: 200px; object-fit: cover;">
      <% else %>
        <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
          <span class="text-white">No Image</span>
        </div>
      <% end %>
      <div class="card-body d-flex flex-column">
        <h5 class="card-title"><%= event.name %></h5>
        <p class="card-text text-muted small">
          <% if event.start_at %>
            <%= event.start_at.strftime("%b %d, %Y at %I:%M %p") %>
          <% end %>
        </p>
        <p class="card-text flex-grow-1"><%= truncate(event.description, length: 100) %></p>
        <div class="d-flex justify-content-between align-items-center mt-3">
          <div class="btn-group" role="group" aria-label="Vote controls">
            <%= link_to "👍", upvote_event_path(event, page: params[:page]), method: :patch, aria: { label: "Upvote" }, role: "button" %>
            &nbsp;<%= event.event_vote_counter&.upvotes_count || 0 %> &nbsp;
            &nbsp;<%= link_to "👎", downvote_event_path(event, page: params[:page]), method: :patch, aria: { label: "Downvote" }, role: "button" %>
            <%= event.event_vote_counter&.downvotes_count || 0 %>
          </div>
          <span class="badge bg-primary"><%= pluralize((event.event_vote_counter&.upvotes_count || 0) + (event.event_vote_counter&.downvotes_count || 0), "vote") %></span>
        </div>
      </div>
    </div>
  </div>
<% end %>
